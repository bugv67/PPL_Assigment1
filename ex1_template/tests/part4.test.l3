#lang racket
(require rackunit)
(require rackunit/text-ui)
;; ==========================================
;; 2. הדפסות חיות (כדי לראות בעיניים!)
;; ==========================================
(displayln "=== מתחיל הדפסות חיות ===")
(displayln (format "last-item of '(1 2 3 4)      => ~a" (last-item '(1 2 3 4))))
(displayln (format "remove-last-item of '(a b c) => ~a" (remove-last-item '(a b c))))
(displayln (format "rotate-nth of '(1 2 3 4) 2   => ~a" (rotate-nth '(1 2 3 4) 2)))
(displayln (format "deep-reverse of '(a (b c) d) => ~a" (deep-reverse '(a (b c) d))))
(displayln "===========================\n")

;; ==========================================
;; 3. הבדיקות האוטומטיות (המלאות!)
;; ==========================================
(define tests
    (test-suite "Assignment 1 - Part 4"
        
        (test-suite "last-item"
            ;; הטסטים המקוריים שלך
            (check-equal? (last-item '(1 2 3)) 3)
            (check-equal? (last-item '(a b c)) 'c)
            (check-equal? (last-item '(42)) 42)
            (check-equal? (last-item '("hello" "world")) "world")
            ;; מקרי קצה שהוספנו
            (check-equal? (last-item '(1 2 (3 4))) '(3 4))
            (check-equal? (last-item '((a b))) '(a b))
        )

        (test-suite "remove-last-item"
            ;; הטסטים המקוריים שלך
            (check-equal? (remove-last-item '(1 2 3)) '(1 2))
            (check-equal? (remove-last-item '(a b c d)) '(a b c))
            (check-equal? (remove-last-item '(42)) '())
            (check-equal? (remove-last-item '("hello" "world")) '("hello"))
            ;; מקרי קצה שהוספנו
            (check-equal? (remove-last-item '(1 2 (3 4))) '(1 2))
            (check-equal? (remove-last-item '((a b))) '())
        )

        (test-suite "rotate-nth"
            ;; הטסטים המקוריים שלך
            (check-equal? (rotate-nth '(1 2 3) 1) '(3 1 2))
            (check-equal? (rotate-nth '(a b c d) 2) '(c d a b))
            (check-equal? (rotate-nth '(1 2 3 4 5) 3) '(3 4 5 1 2))
            (check-equal? (rotate-nth '(hello world) 1) '(world hello))
            (check-equal? (rotate-nth '(x y z) 0) '(x y z))
            ;; מקרי קצה שהוספנו
            (check-equal? (rotate-nth '(a b c) 3) '(a b c))
        )
        
        (test-suite "deep-reverse"
            ;; הטסטים המקוריים שלך
            (check-equal? (deep-reverse '(1 2 3)) '(3 2 1))
            (check-equal? (deep-reverse '(a b (c d))) '((d c) b a))
            ;; מקרי קצה שהוספנו
            (check-equal? (deep-reverse '()) '())
            (check-equal? (deep-reverse '(1 () 3)) '(3 () 1))
            (check-equal? (deep-reverse '(1 (2 (3 4)) 5)) '(5 ((4 3) 2) 1))
            (check-equal? (deep-reverse '((1 2) (3 4))) '((4 3) (2 1)))
        )
    )
)

(run-tests tests)